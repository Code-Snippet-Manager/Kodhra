<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Draft | Code Snippet Manager</title>
    <meta name="description"
        content="Kodhra is a developer-first code snippet manager to save, organize, search, and reuse reusable code snippets. Keep all your programming logic in one clean, structured place.">
    <link rel="stylesheet" href="/style/css/partials/Header.css">
    <link rel="stylesheet" href="/style/css/ad_search.css">
    <link rel="stylesheet" href="/style/css/Notification.css">
    <link rel="stylesheet" href="/style/css/index.css">
    <link rel="stylesheet" href="/style/css/chip.css">
    <link rel="stylesheet" href="/style/css/card.css">
    <link rel="stylesheet" href="/style/css/loader.css">
    <link rel="stylesheet" href="/style/css/folder.css">
    <link rel="stylesheet" href="/style/css/toast.css">
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon" />
    <link rel="shortcut icon" href="/assets/logo.webp" type="image/png" />
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.6/dist/purify.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@codewithajoydas/toastmaster@2.3.5/dist/toaster.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@codewithajoydas/toastmaster@2.3.5/dist/toaster.min.css">
</head>

<body data-theme="light">
    <%- include("partials/loader.ejs") %>
        <div class="content">
            <%- include("partials/header.ejs")%>
                <div class="container">
                    <%- include("partials/sidebar.ejs", { navigation: 'draft' })%>
                        <main style="width: 100%; height: calc(100vh - 70px);">
                            <div class="page_title" onclick="collapse(this)"
                                style="white-space: nowrap; width: fit-content !important;">
                                <span class="down"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
                                        viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                        stroke-linecap="round" stroke-linejoin="round"
                                        class="   -chevron-down-icon  -chevron-down">
                                        <path d="m6 9 6 6 6-6" />
                                    </svg></span>
                                All Drafts & Temporary Snippets
                            </div>
                            <div id="cards">
                                <%- include("partials/cards.ejs", {showStatus: true})%>
                            </div>
                            <%- include("partials/fab")%>

                        </main>
                        <div class="notification-bar">
                            <h3>Notifications</h3>
                            <ul class="notification-lists">
                            </ul>
                        </div>
                        <div id="context_menu"
                            style="position: absolute;top: 0;left: 0;display: none;z-index: 1000000;width: 200px;">
                            <ul id="context_menu_list"></ul>
                        </div>



                        <div class="notification-bar">
                            <h3>Notifications</h3>
                            <ul class="notification-lists">
                            </ul>
                        </div>
    <style>
      .enableNotification {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999999;
        backdrop-filter: blur(2px);
      }
    
      .notify-card {
        width: 360px;
        background: var(--bg-color);
        border-radius: 16px;
        padding: 20px 22px;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
      }
    
      .notify-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
      }
    
      .notify-header img {
        width: 42px;
        height: 42px;
      }
    
      .notify-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: #111;
      }
    
      .notify-text {
        font-size: 14px;
        color: #555;
        line-height: 1.5;
        margin-bottom: 14px;
      }
    
      .notify-list {
        margin: 0 0 18px;
        padding-left: 18px;
        font-size: 13px;
        color: #444;
      }
    
      .notify-list li {
        margin-bottom: 6px;
      }
    
      .notify-actions {
        display: flex;
        gap: 10px;
      }
    
      .notify-actions button {
        flex: 1;
        padding: 10px 0;
        border-radius: 5px;
        font-size: 14px;
        cursor: pointer;
        border: none;
      }
    
      .btn-enable {
        --bg-color: #6d5efc;
        background: var(--bg-color);
        color: #fff;
        font-weight: 500;
      }
    
      .btn-later {
        background: var(--accent);
        color: #444;
      }
    </style>
    
    <div class="enableNotification">
      <div class="notify-card">
        <div class="notify-header">
          <img src="https://cdn3d.iconscout.com/3d/premium/thumb/check-notification-bell-3d-icon-png-download-10489313.png"
            alt="Notification Bell" />
          <h3>Stay in the loop</h3>
        </div>
    
        <p class="notify-text">
          Enable notifications to get timely updates about activity in your workspace.
        </p>
    
        <ul class="notify-list">
          <li>When someone shares a snippet</li>
          <li>Collaboration updates</li>
          <li>Someone Like your snippet</li>
          <li>New Followers in your workspace</li>
          <li>Security & important alerts</li>
        </ul>
    
        <div class="notify-actions">
          <button class="btn-enable" onclick="initPush()">Enable Notifications</button>
          <button class="btn-later" onclick="closeModel()">Maybe later</button>
        </div>
      </div>
    </div>


                        <div class="networkInfo" style="display: none;">
                            <span><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round" class="   -info-icon  -info">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 16v-4" />
                                    <path d="M12 8h.01" />
                                </svg></span>

                            <span id="networkInfo"></span>
                        </div>
                </div>
        </div>

        <script src="/scripts/ad_search.js"></script>
        <script src="/scripts/Fab.js"></script>
        <script src="/scripts/Notification.js"></script>
        <script src="/scripts/searchFunction.js"></script>
        <script src="/scripts/isonline.js"></script>
        <script src="/scripts/header.js"></script>
        <script src="/scripts/collapse.js"></script>
        <script src="/scripts/Tooltips.js"></script>
        <script src="/scripts/saveDraft.js"></script>
        <script src="/scripts/context_menu.js"></script>
        <script src="/scripts/shortcut.js"></script>


        <script>
            const opendb = indexedDB.open("draftDB", 1);
            let openDataBase;
            opendb.onupgradeneeded = function () {
                openDataBase = opendb.result;
                if (!openDataBase.objectStoreNames.contains("drafts")) {
                    openDataBase.createObjectStore("drafts");
                }
            };
            opendb.onerror = function () {
                console.log("Database Error");
            };
            opendb.onsuccess = function () {
                openDataBase = opendb.result;
                const tx = openDataBase.transaction("drafts", "readonly");
                const store = tx.objectStore("drafts");
                const request = store.getAll();
                request.onsuccess = function () {
                    const drafts = request.result;
                    drafts.forEach((draft) => {
                        const card = createCard(draft);
                        document.getElementById("cards").insertAdjacentHTML("beforeend", card);
                    });
                };
            };


            function safe(v) {
                return DOMPurify.sanitize(v, { ALLOWED_TAGS: [] });
            }
            function createCard(e) {
                return `
<div class="card" id="card-${e.id}"
  ondblclick="window.open('/card/${e.id}', '_blank')"
  data-id="${e.id}"
  tabindex="0"
  data-menus="draft_Delete, draft_Edit"
  data-userId="<%= userId %>"
  data-contextMenu="true"
  data-cardName="${safe(e.title)}"
  data-mtype="card"
  data-url="/card/create/#/${e.id}"
  data-cardauthor="${e.author?._id}"
  data-cardcontent="${safe(`${e.title || "No Title"}, ${e.description || "No Description"}, ${e.content || "No Content"}`)}">

  <div class="header-info">
    <label for="card_${e._id}" style="display:flex;align-items:center;gap:10px">
      <img
        src="${safe(e.author?.userImage)}"
        alt=""
        width="40"
        height="40"
        class="profileImage"
        style="border-radius:50%"
        onerror="this.src='https://static.vecteezy.com/system/resources/previews/013/360/247/non_2x/default-avatar-photo-icon-social-media-profile-sign-symbol-vector.jpg'"
      />

      <div class="title">
        <p>
          ${safe(e.title || "No Title")}
          <span style="
            font-size:13px;
            display:block;
            width:300px;
            text-overflow:ellipsis;
            overflow:hidden;
            white-space:nowrap;
          ">
            ${safe(e.description || "No Description")}
          </span>
        </p>

        <div>
          <span class="author" style="display:inline-block;">
            <strong>
              <a href="/profile/${encodeURIComponent(e.author?.userName)}">
                ${safe(e.author?.userName || "No Username")}
              </a>
            </strong>
          </span>,
          <span class="lan">${safe(e?.category)}</span>,
          <span class="time">
            ${new Date(e.createdAt).toLocaleString() || "No Date"}
          </span>
        </div>
      </div>
    </label>

    <div style="width:100px;display:flex;justify-content:end;align-items:center;gap:10px;">
    <span style="cursor:pointer;font-size: x-small; font-weight: 600; text-transform: capitalize; padding: 2px 5px; background: pink;border-radius: 5px; color:red ">Temporary</span>
      <div class="menu_top d-n"
        data-menu-id="${e.id}"
        data-id="${e.id}"
        data-url="/card/create/#/${e.id}"
        data-tooltip="Open Menu"
        data-menus="draft_Delete, draft_Edit"
        onclick="openContextMenu(event)"
        data-userId="<%= userId %>"

        data-cardauthor="${e?.author?._id}"
        data-cardName="${safe(e.title || "No Title")}"
        data-mtype="card"
        data-contextMenu="true"
        tabindex="0">

        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
          viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          class="   -ellipsis-vertical">
          <circle cx="12" cy="12" r="1" />
          <circle cx="12" cy="5" r="1" />
          <circle cx="12" cy="19" r="1" />
        </svg>
      </div>
    </div>
  </div>

  <div class="code" title="${safe(e.content || "No Content")}">
    <pre><code style="font-size: small !important;">${safe(e.content || "No Content")}</code></pre>
  </div>

  ${e.tags && e.tags.length
                        ? `
    <div class="tags d-n">
      ${e.tags
                            .map(
                                tag => `
        <a class="span" href="search?query=${encodeURIComponent(tag)}">
          ${safe(tag)}
        </a>
      `
                            )
                            .join("")}
    </div>
    `
                        : ""
                    }

  <div class="options d-n">
    <div class="open"
      tabindex="0"
      style="display:flex;justify-content:center;align-items:center;gap:10px;cursor:pointer;"
      data-code="${safe(e.content || "No Content")}">

      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
        viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round"
        class="   -clipboard-copy">
        <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
        <path d="M8 4H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
        <path d="M16 4h2a2 2 0 0 1 2 2v4" />
        <path d="M21 14H11" />
        <path d="m15 10-4 4 4 4" />
      </svg>

      <span>Copy Code</span>
    </div>

    <div class="sub_menu">
      <div class="gist_upload" onclick="copy_cdn_link(event)" data-tooltip="Copy CDN Link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20"
          viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          class="   -link">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
      </div>

      <div class="pin"
        onclick="pinIt(this,'${e.id}')"
        data-tooltip="Pin"
        data-id="${e.id}"
        tabindex="0">

        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
          viewBox="0 0 24 24"
          class="${e.isPinned ? "active" : ""}"
          fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round"
          class="   -pin">
          <path d="M12 17v5" />
          <path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
        </svg>
      </div>

      <div style="display:flex;align-items:center;gap:4px;">
        <span style="font-size:small" class="like-count">
          ${e?.likes?.length || 0}
        </span>

        <div class="fav"
          data-tooltip="Favorite"
          onclick="favIt(this,'${e.id}')"
          data-id="${e.id}"
          tabindex="0">

          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
            viewBox="0 0 24 24"
            class="${e?.isFavorite ? "active" : ""}"
            fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round"
            class="   -star">
            <path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>
`;

            }

        </script>
</body>

</html>